# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
ENV/
env/

# Local environment variables / secrets
.env
.env.*
!.env.example

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/

