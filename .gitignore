*.log
*.tmp
*.temp

# IDE / editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Local data artifacts (generated at runtime)
data/uploads/
data/chroma/
data/*.db
